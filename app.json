{
  "package_id": "com.mrmartellato.aviationweather",
  "edition": "202601",
  "name": "Aviation Weather",
  "version": "1.0.0",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.7",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Access NOAA aviation weather APIs and D-ATIS feeds.",
      "whitelist": [
        "aviationweather.gov",
        "api.ipify.org",
        "ip-api.com",
        "ipapi.co",
        "datis.clowd.io",
        "corsproxy.io"
      ]
    },
    {
      "name": "location",
      "desc": "Locate the nearest METAR/TAF weather reporting stations."
    }
  ],
  "supported_languages": [
    "en"
  ]
}